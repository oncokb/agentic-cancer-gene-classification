# Required for Anthropic SDK mode.
# Optional when using --local or request.local_backend with a local agent CLI.
# Create at https://platform.claude.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional: OncoKB API token for membership lookups
# Non-technical users can paste this token in the UI setup screen instead.
# Requires OncoKB account/data-access approval. Get from https://www.oncokb.org/account/settings
ONCOKB_API_TOKEN=

# Optional: NCBI API key for higher rate limits (10/sec vs 3/sec)
# Non-technical users can paste this key in the UI setup screen instead.
# Get from https://support.nlm.nih.gov/kbArticle/?pn=KA-05317
NCBI_API_KEY=

# Optional: local Google service account JSON path for direct Google Sheets export.
# Non-technical users can upload this JSON in the UI setup screen instead.
# Share the target spreadsheet with the service account email before exporting.
GOOGLE_SERVICE_ACCOUNT_JSON=

# LLM model to use for synthesis (default: claude-opus-4-7)
SYNTHESIS_MODEL=claude-opus-4-7

# LLM model for the citation selection pass — cheaper/faster than synthesis model
SELECTION_MODEL=claude-haiku-4-5-20251001

# Max PubMed abstracts to retrieve per gene across all Tier 1 queries (default: 50)
PUBMED_MAX_RESULTS=50

# Minimum papers to declare strong cancer association before falling to Tier 2 (default: 4)
MIN_PAPERS_FOR_STRONG_ASSOCIATION=4

# Papers passed to synthesis after selection pass (default: 8)
# Increasing improves recall at the cost of larger synthesis context and higher token cost
MAX_PAPERS_FOR_SYNTHESIS=8

# Deterministic records retained before LLM relevance selection (default: 24)
SELECTION_PREFILTER_LIMIT=24

# Chunk size for LLM relevance selection (default: 10)
SELECTION_CHUNK_SIZE=10

# PMIDs retained per relevance-selection chunk before final merge (default: 3)
SELECTION_CHUNK_KEEP=3

# Fallback compact evidence text per paper when evidence extraction fails (default: 900)
SYNTHESIS_EVIDENCE_MAX_CHARS=900

# In local mode, skip Tier 2 exploration below this deterministic relevance score (default: 2)
LOCAL_TIER2_MIN_PREFILTER_SCORE=2

# Max PMIDs emitted per annotation after verification (default: 4)
# Lower values favor citation precision; higher values may improve citation recall
MAX_CITATIONS_PER_ANNOTATION=4

# Number of genes to annotate concurrently (default: 3)
# Higher values reduce batch latency but may spawn more local-agent/API calls at once
MAX_GENE_ANNOTATION_CONCURRENCY=3

# Hours to reuse the local OncoKB curated-gene cache before refreshing (default: 24)
# Set to 0 to disable persistent OncoKB gene-list caching.
ONCOKB_GENE_CACHE_TTL_HOURS=24

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Docker local-agent mode:
#   docker compose --profile local up --build annotation-service-local
#
# The local profile installs Codex and Claude Code CLIs in the container and mounts:
#   ${HOME}/.codex -> /home/appuser/.codex
#   ${HOME}/.claude -> /home/appuser/.claude
#   ${HOME}/.claude.json -> /home/appuser/.claude.json
#
# API calls can then include:
#   {"fusions":["TP53::BRAF"],"local_backend":"codex"}
